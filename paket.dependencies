source https://api.nuget.org/v3/index.json

storage: none

// Exact pin -- only this version is acceptable
nuget Newtonsoft.Json == 13.0.3

// Pessimistic constraint -- >= 3.1.0 && < 3.2.0
nuget Serilog ~> 3.1

// Range -- any version in [8.0.0, 9.0.0)
nuget Microsoft.Extensions.Logging >= 8.0.0 < 9.0.0

// Prerelease allowed -- resolver may pick a prerelease build
nuget Microsoft.Bcl.AsyncInterfaces >= 8.0.0 prerelease
